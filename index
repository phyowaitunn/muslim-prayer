<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Prayer Time App</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="container">
        <h1>🕌 Prayer Times</h1>
        <p id="location">Detecting location...</p>
        <p id="date"></p>

        <div class="prayer-box">
            <div class="prayer">
                <h3>Fajr</h3>
                <p id="fajr">--:--</p>
            </div>
            <div class="prayer">
                <h3>Dhuhr</h3>
                <p id="dhuhr">--:--</p>
            </div>
            <div class="prayer">
                <h3>Asr</h3>
                <p id="asr">--:--</p>
            </div>
            <div class="prayer">
                <h3>Maghrib</h3>
                <p id="maghrib">--:--</p>
            </div>
            <div class="prayer">
                <h3>Isha</h3>
                <p id="isha">--:--</p>
            </div>
        </div>

        <button onclick="getPrayerTimes()">Refresh</button>
    </div>

    <script src="script.js"></script>
</body>
</html>
